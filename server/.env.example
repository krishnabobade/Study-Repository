# ============================================================
# Study Repository — Server Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ============================================================

# ---- Server Configuration ----
PORT=5000
NODE_ENV=development

# ---- Database ----
# MongoDB Atlas connection string (production) or local URI (development)
MONGO_URI=mongodb://localhost:27017/studyrepo

# ---- Security ----
# REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_character_random_hex_string_here
JWT_EXPIRE=7d

# ---- Admin Account ----
# REQUIRED: The email address of the primary admin account.
# This controls who can access administrative features.
# Set this to your institutional admin email.
ADMIN_EMAIL=admin@yourinstitution.edu

# ---- Allowed Domain ----
# Only users with this email domain can register
ALLOWED_DOMAIN=@yourinstitution.edu

# ---- Frontend URL (for CORS & email links) ----
FRONTEND_URL=http://localhost:5173

# ---- Cloudinary (Media/Document Storage) ----
# Sign up at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---- Email (SMTP - Resend) ----
# Sign up at: https://resend.com
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_USERNAME=resend
EMAIL_PASSWORD=re_YOUR_RESEND_API_KEY
EMAIL_FROM=noreply@yourdomain.com

# ---- AI Content Analysis (Gemini) ----
# Optional: Enables AI-powered academic content validation on uploads
# Sign up at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key

# ---- AWS S3 (Optional Enterprise Storage) ----
# Set USE_AWS_S3=true to use S3 instead of Cloudinary for file storage
USE_AWS_S3=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=your_bucket_name

# ---- Deployment (Render / Production) ----
# Set these on your hosting platform, not in this file
RENDER_EXTERNAL_URL=https://your-backend.onrender.com
BACKEND_URL=https://your-backend.onrender.com

# ---- Database Seeding ----
# Used only when running node seed.js — never use in production
SEED_ADMIN_PASSWORD=ChangeThisToAStrongPassword123!
